# Database Connection URL (Managed via prisma.config.ts)
DATABASE_URL="file:./dev.db"

# DeepSeek LLM Provider Configuration
DEEPSEEK_API_KEY="your-deepseek-api-key-here"

# Lead Notifications (Optional)
# Configure either a Slack Webhook or Resend API key to receive notifications when a new lead is captured.
# Slack integration:
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Resend Email integration:
RESEND_API_KEY="re_..."
LEAD_NOTIFICATION_EMAIL="hello@cortexhive.agency"
