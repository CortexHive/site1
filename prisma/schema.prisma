// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  projectType String
  budget      String
  timeline    String
  brief       String
  source      String   // "form" or "chatbot"
  createdAt   DateTime @default(now())
}

model Newsletter {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}
